<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="750.0" prefWidth="1550.0" style="-fx-background-color: linear-gradient(to bottom right, #0a0f2c, #121a4a);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.algoviz.algoviz.Queue_Controller">

    <!-- ═══════════════════════════════════════════════════════════
         LEFT SIDEBAR
         ═══════════════════════════════════════════════════════════ -->
    <StackPane prefHeight="750.0" prefWidth="260.0" style="-fx-background-color: #000118;                       -fx-border-color: rgba(123,47,247,0.4);                       -fx-border-width: 0 2 0 0;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0">

        <VBox alignment="TOP_CENTER" prefHeight="750.0" prefWidth="267.0" spacing="0">

            <!-- Logo area -->
            <VBox alignment="CENTER" prefHeight="180" style="-fx-background-color: rgba(123,47,247,0.15);                          -fx-border-color: rgba(123,47,247,0.3);                          -fx-border-width: 0 0 2 0;                          -fx-padding: 20 10 20 10;">
                <Label style="-fx-font-size: 42px;" text="🚶" />
                <Label style="-fx-font-family: Verdana; -fx-font-size: 30px;                               -fx-font-weight: bold; -fx-text-fill: #00ff00;" text="QUEUE" />
                <Label style="-fx-font-family: Verdana; -fx-font-size: 15px;                               -fx-font-weight: bold; -fx-text-fill: rgba(0,255,0,0.6);                               -fx-padding: 2 0 0 0;" text="VISUALIZER" />
            </VBox>

            <!-- Operations label -->
            <Label style="-fx-font-family: Verdana; -fx-font-size: 11px;                           -fx-text-fill: rgba(123,47,247,0.8); -fx-font-weight: bold;                           -fx-padding: 18 0 10 0;" text="OPERATIONS" />

            <!-- Enqueue button -->
            <Button fx:id="enqueueBtn" mnemonicParsing="false" onAction="#onEnqueueClicked" prefHeight="70" prefWidth="190.0" style="-fx-font-family: Verdana; -fx-font-size: 20px;                            -fx-font-weight: bold; -fx-text-fill: white;                            -fx-background-color: linear-gradient(to bottom right, #00c853, #007a2f);                            -fx-background-radius: 12px; -fx-cursor: hand;                            -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 20;" text="➡  Enqueue" />
            <Region prefHeight="12" />

            <!-- Dequeue button -->
            <Button fx:id="dequeueBtn" mnemonicParsing="false" onAction="#onDequeueClicked" prefHeight="70" prefWidth="190.0" style="-fx-font-family: Verdana; -fx-font-size: 20px;                            -fx-font-weight: bold; -fx-text-fill: white;                            -fx-background-color: linear-gradient(to bottom right, #c62828, #b71c1c);                            -fx-background-radius: 12px; -fx-cursor: hand;                            -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 20;" text="⬅  Dequeue" />
            <Region prefHeight="12" />

            <!-- Peek front button -->
            <Button fx:id="peekBtn" mnemonicParsing="false" onAction="#onPeekClicked" prefHeight="70" prefWidth="190.0" style="-fx-font-family: Verdana; -fx-font-size: 20px;                            -fx-font-weight: bold; -fx-text-fill: white;                            -fx-background-color: linear-gradient(to bottom right, #f57f17, #e65100);                            -fx-background-radius: 12px; -fx-cursor: hand;                            -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 20;" text="👁  Peek Front" />

            <Region VBox.vgrow="ALWAYS" />

            <Separator prefWidth="260" style="-fx-background-color: rgba(123,47,247,0.3);" />
            <Region prefHeight="10" />

            <!-- Home button -->
            <Button fx:id="home_btn" mnemonicParsing="false" onAction="#onBackClicked" prefHeight="55" prefWidth="160.0" style="-fx-font-family: Verdana; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: rgba(123,47,247,0.35); -fx-background-radius: 12px; -fx-cursor: hand; -fx-alignment: CENTER; -fx-padding: 0 0 0 20; -fx-border-color: rgba(123,47,247,0.5); -fx-border-radius: 12px; -fx-border-width: 1;" text="🏠  Home" />
            <Region prefHeight="20" />

        </VBox>
    </StackPane>

    <!-- ═══════════════════════════════════════════════════════════
         MAIN CONTENT
         ═══════════════════════════════════════════════════════════ -->
    <VBox layoutX="260.0" prefHeight="750.0" prefWidth="1290.0" spacing="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="260.0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <!-- ── TOP BAR ── -->
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #000118;                      -fx-padding: 12 24 12 24;                      -fx-border-color: rgba(123,47,247,0.35);                      -fx-border-width: 0 0 2 0;">

            <!-- Title -->
            <VBox alignment="CENTER_LEFT" spacing="2">
                <Label style="-fx-font-family: Verdana; -fx-font-size: 9px;                               -fx-text-fill: rgba(123,47,247,0.7); -fx-font-weight: bold;" text="DATA STRUCTURE" />
                <Label style="-fx-font-family: Verdana; -fx-font-size: 20px;                               -fx-font-weight: bold; -fx-text-fill: #00ff00;" text="Queue  —  Array Representation" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Enqueue value input -->
            <VBox alignment="CENTER_LEFT" spacing="3">
                <Label style="-fx-font-family: Verdana; -fx-font-size: 9px;                               -fx-text-fill: rgba(170,170,170,0.8); -fx-font-weight: bold;" text="ENQUEUE VALUE" />
                <TextField fx:id="valueField" prefWidth="120" promptText="e.g.  42" style="-fx-background-color: #0a1030; -fx-text-fill: white;                                   -fx-prompt-text-fill: #444;                                   -fx-border-color: rgba(123,47,247,0.5);                                   -fx-border-width: 1; -fx-background-radius: 8;                                   -fx-border-radius: 8; -fx-font-family: Verdana;                                   -fx-font-size: 14px; -fx-padding: 6 10 6 10;" />
            </VBox>

            <!-- Max size input -->
            <VBox alignment="CENTER_LEFT" spacing="3">
                <Label style="-fx-font-family: Verdana; -fx-font-size: 9px;                               -fx-text-fill: rgba(170,170,170,0.8); -fx-font-weight: bold;" text="MAX SIZE" />
                <TextField fx:id="maxSizeField" prefWidth="90" promptText="e.g.  10" style="-fx-background-color: #0a1030; -fx-text-fill: white;                                   -fx-prompt-text-fill: #444;                                   -fx-border-color: rgba(123,47,247,0.5);                                   -fx-border-width: 1; -fx-background-radius: 8;                                   -fx-border-radius: 8; -fx-font-family: Verdana;                                   -fx-font-size: 14px; -fx-padding: 6 10 6 10;" />
            </VBox>

            <!-- Set Size button -->
            <Button onAction="#onSetSizeClicked" prefHeight="40" prefWidth="90" style="-fx-font-family: Verdana; -fx-font-size: 12px;                            -fx-font-weight: bold; -fx-text-fill: white;                            -fx-background-color: linear-gradient(to bottom right, #8e2de2, #4a00e0);                            -fx-background-radius: 10px; -fx-cursor: hand;" text="Set Size" />

            <!-- Clear button -->
            <Button onAction="#onClearClicked" prefHeight="40" prefWidth="100" style="-fx-font-family: Verdana; -fx-font-size: 12px;                            -fx-font-weight: bold; -fx-text-fill: white;                            -fx-background-color: linear-gradient(to bottom right, #37474f, #263238);                            -fx-background-radius: 10px; -fx-cursor: hand;" text="🗑  Clear" />

        </HBox>

        <!-- ── INFO BAR ── -->
        <HBox alignment="CENTER_LEFT" spacing="30" style="-fx-background-color: #000118;                      -fx-border-color: rgba(123,47,247,0.3);                      -fx-border-width: 0 0 1 0; -fx-padding: 8 24 8 24;">

            <Label style="-fx-font-family: Verdana; -fx-font-size: 10px;                           -fx-font-weight: bold; -fx-text-fill: rgba(123,47,247,0.8);" text="QUEUE INFO" />

            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label style="-fx-text-fill: #aaaaaa; -fx-font-family: Verdana; -fx-font-size: 12px;" text="Size :" />
                <Label fx:id="sizeLabel" style="-fx-text-fill: #00ff00; -fx-font-family: Verdana;                               -fx-font-size: 12px; -fx-font-weight: bold;" text="0" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label style="-fx-text-fill: #aaaaaa; -fx-font-family: Verdana; -fx-font-size: 12px;" text="Capacity :" />
                <Label fx:id="capacityLabel" style="-fx-text-fill: #00ff00; -fx-font-family: Verdana;                               -fx-font-size: 12px; -fx-font-weight: bold;" text="10" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label style="-fx-text-fill: #aaaaaa; -fx-font-family: Verdana; -fx-font-size: 12px;" text="Front :" />
                <Label fx:id="frontLabel" style="-fx-text-fill: #66BB6A; -fx-font-family: Verdana;                               -fx-font-size: 12px; -fx-font-weight: bold;" text="—" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label style="-fx-text-fill: #aaaaaa; -fx-font-family: Verdana; -fx-font-size: 12px;" text="Rear :" />
                <Label fx:id="rearLabel" style="-fx-text-fill: #4FC3F7; -fx-font-family: Verdana;                               -fx-font-size: 12px; -fx-font-weight: bold;" text="—" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label style="-fx-text-fill: #aaaaaa; -fx-font-family: Verdana; -fx-font-size: 12px;" text="Empty :" />
                <Label fx:id="isEmptyLabel" style="-fx-text-fill: #4FC3F7; -fx-font-family: Verdana;                               -fx-font-size: 12px; -fx-font-weight: bold;" text="true" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label style="-fx-text-fill: #aaaaaa; -fx-font-family: Verdana; -fx-font-size: 12px;" text="Full :" />
                <Label fx:id="isFullLabel" style="-fx-text-fill: #4FC3F7; -fx-font-family: Verdana;                               -fx-font-size: 12px; -fx-font-weight: bold;" text="false" />
            </HBox>
        </HBox>

        <!-- ── MAIN BODY ── -->
        <HBox spacing="0" VBox.vgrow="ALWAYS">

            <!-- Queue canvas -->
            <Pane fx:id="queueVisualPane" prefHeight="646.0" prefWidth="888.0" style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS" />

            <!-- Right panel — log only -->
            <VBox prefWidth="293.0" spacing="0" style="-fx-background-color: #000118;                          -fx-border-color: rgba(123,47,247,0.3);                          -fx-border-width: 0 0 0 2;">
            <children>
   
                   <!-- Operation log -->
                   <VBox prefHeight="646.0" prefWidth="275.0" spacing="10" style="-fx-padding: 16 18 16 18;">
   
                       <Label style="-fx-font-family: Verdana; -fx-font-size: 11px;                                   -fx-font-weight: bold;                                   -fx-text-fill: rgba(123,47,247,0.8);" text="OPERATION LOG" />
   
                       <ListView fx:id="operationLog" prefHeight="634.0" prefWidth="293.0" style="-fx-background-color: #0a0f2c;                                      -fx-border-color: rgba(123,47,247,0.3);                                      -fx-border-width: 1; -fx-background-radius: 8;                                      -fx-border-radius: 8;                                      -fx-control-inner-background: #0a0f2c;" VBox.vgrow="ALWAYS" />
                   </VBox>
            </children>

            </VBox>
        </HBox>

    </VBox>

</AnchorPane>
