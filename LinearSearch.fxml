<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="750.0" prefWidth="1550.0" style="-fx-background-color: linear-gradient(to bottom right, #0a0f2c, #121a4a);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.algoviz.algoviz.Search_Controller">

    <!-- ═══════════════════════════════════════════════════════════
         LEFT SIDEBAR
         ═══════════════════════════════════════════════════════════ -->
    <StackPane prefWidth="300.0" style="-fx-background-color: #000118;                       -fx-border-color: rgba(123,47,247,0.4);                       -fx-border-width: 0 2 0 0;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0">

        <VBox alignment="TOP_CENTER" spacing="0">

            <!-- Logo area -->
            <VBox alignment="CENTER" prefHeight="180" style="-fx-background-color: rgba(123,47,247,0.15);                          -fx-border-color: rgba(123,47,247,0.3);                          -fx-border-width: 0 0 2 0;                          -fx-padding: 20 10 20 10;">
                <Label style="-fx-font-size: 42px;" text="🔍" />
                <Label style="-fx-font-family: Verdana; -fx-font-size: 30px;                               -fx-font-weight: bold; -fx-text-fill: #00ff00;" text="SEARCH" />
                <Label style="-fx-font-family: Verdana; -fx-font-size: 15px;                               -fx-font-weight: bold; -fx-text-fill: rgba(0,255,0,0.6);                               -fx-padding: 2 0 0 0;" text="VISUALIZER" />
            </VBox>

            <!-- Nav label -->
            <Label style="-fx-font-family: Verdana; -fx-font-size: 11px;                           -fx-text-fill: rgba(123,47,247,0.8); -fx-font-weight: bold;                           -fx-padding: 18 0 10 0;" text="ALGORITHMS" />

            <!-- Linear Search btn -->
            <Button fx:id="linear_search_btn" mnemonicParsing="false" onAction="#load_linear_search" prefHeight="70" prefWidth="260" style="-fx-font-family: Verdana; -fx-font-size: 17px;                            -fx-font-weight: bold; -fx-text-fill: white;                            -fx-background-color: linear-gradient(to bottom right, #8e2de2, #4a00e0);                            -fx-background-radius: 12px; -fx-cursor: hand;                            -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 20;" text="📋  Linear Search" />

            <Region prefHeight="12" />

            <!-- Binary Search btn -->
            <Button fx:id="binary_search_btn" mnemonicParsing="false" onAction="#load_binary_search" prefHeight="70" prefWidth="260" style="-fx-font-family: Verdana; -fx-font-size: 17px;                            -fx-font-weight: bold; -fx-text-fill: white;                            -fx-background-color: linear-gradient(to bottom right, #8e2de2, #4a00e0);                            -fx-background-radius: 12px; -fx-cursor: hand;                            -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 20;" text="⚡  Binary Search" />

            <Region VBox.vgrow="ALWAYS" />

            <Separator prefWidth="260" style="-fx-background-color: rgba(123,47,247,0.3);" />
            <Region prefHeight="10" />

            <!-- Home btn -->
            <Button fx:id="home_btn" mnemonicParsing="false" onAction="#onBackClicked" prefHeight="55" prefWidth="160.0" style="-fx-font-family: Verdana; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: rgba(123,47,247,0.35); -fx-background-radius: 12px; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 20; -fx-border-color: rgba(123,47,247,0.5); -fx-border-radius: 12px; -fx-border-width: 1;" text="🏠  Home" />
            <Region prefHeight="20" />

        </VBox>
    </StackPane>

    <!-- ═══════════════════════════════════════════════════════════
         MAIN CONTENT
         ═══════════════════════════════════════════════════════════ -->
    <VBox spacing="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="300" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <!-- ── TOP BAR ── -->
        <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-background-color: #000118;                      -fx-padding: 12 24 12 24;                      -fx-border-color: rgba(123,47,247,0.35);                      -fx-border-width: 0 0 2 0;">

            <!-- Active algo badge -->
            <VBox alignment="CENTER_LEFT" spacing="2">
                <Label style="-fx-font-family: Verdana; -fx-font-size: 9px;                               -fx-text-fill: rgba(123,47,247,0.7); -fx-font-weight: bold;" text="NOW VIEWING" />
                <Label fx:id="activeAlgoLabel" style="-fx-font-family: Verdana; -fx-font-size: 20px;                               -fx-font-weight: bold; -fx-text-fill: #00ff00;" text="Linear Search" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Target input -->
            <VBox alignment="CENTER_LEFT" spacing="3">
                <Label style="-fx-font-family: Verdana; -fx-font-size: 9px;                               -fx-text-fill: rgba(170,170,170,0.8); -fx-font-weight: bold;" text="TARGET VALUE" />
                <TextField fx:id="targetField" prefWidth="110" promptText="e.g.  42" style="-fx-background-color: #0a1030; -fx-text-fill: white;                                   -fx-prompt-text-fill: #444;                                   -fx-border-color: rgba(123,47,247,0.5);                                   -fx-border-width: 1; -fx-background-radius: 8;                                   -fx-border-radius: 8; -fx-font-family: Verdana;                                   -fx-font-size: 14px; -fx-padding: 6 10 6 10;" />
            </VBox>

            <!-- Array size input -->
            <VBox alignment="CENTER_LEFT" spacing="3">
                <Label style="-fx-font-family: Verdana; -fx-font-size: 9px;                               -fx-text-fill: rgba(170,170,170,0.8); -fx-font-weight: bold;" text="ARRAY SIZE" />
                <TextField fx:id="arraySizeField" prefWidth="80" promptText="2–50" style="-fx-background-color: #0a1030; -fx-text-fill: white;                                   -fx-prompt-text-fill: #444;                                   -fx-border-color: rgba(123,47,247,0.5);                                   -fx-border-width: 1; -fx-background-radius: 8;                                   -fx-border-radius: 8; -fx-font-family: Verdana;                                   -fx-font-size: 14px; -fx-padding: 6 10 6 10;" />
            </VBox>

            <!-- ▶ Search -->
            <Button onAction="#onSearchClicked" prefHeight="40" prefWidth="110" style="-fx-font-family: Verdana; -fx-font-size: 13px;                            -fx-font-weight: bold; -fx-text-fill: white;                            -fx-background-color: linear-gradient(to bottom right, #00c853, #007a2f);                            -fx-background-radius: 10px; -fx-cursor: hand;" text="▶  Search" />

            <!-- ⟳ Reset -->
            <Button onAction="#onResetClicked" prefHeight="40" prefWidth="100" style="-fx-font-family: Verdana; -fx-font-size: 13px;                            -fx-font-weight: bold; -fx-text-fill: white;                            -fx-background-color: linear-gradient(to bottom right, #8e2de2, #4a00e0);                            -fx-background-radius: 10px; -fx-cursor: hand;" text="⟳  Reset" />

            <!-- ⏸ Pause / ▶ Resume -->
            <Button fx:id="pauseBtn" disable="true" onAction="#onPauseClicked" prefHeight="40" prefWidth="110" style="-fx-font-family: Verdana; -fx-font-size: 13px;                            -fx-font-weight: bold; -fx-text-fill: white;                            -fx-background-color: linear-gradient(to bottom right, #f57f17, #e65100);                            -fx-background-radius: 10px; -fx-cursor: hand;" text="⏸  Pause" />

            <!-- STEP CONTROLS -->
            <VBox alignment="CENTER" spacing="3">
                <Label style="-fx-font-family: Verdana; -fx-font-size: 9px;                               -fx-text-fill: rgba(170,170,170,0.8); -fx-font-weight: bold;" text="STEP CONTROL" />
                <HBox alignment="CENTER" spacing="6">

                    <!-- ◀ Step Back -->
                    <Button fx:id="stepBackBtn" disable="true" onAction="#onStepBack" prefHeight="36" prefWidth="90" style="-fx-font-family: Verdana; -fx-font-size: 12px;                                    -fx-font-weight: bold; -fx-text-fill: white;                                    -fx-background-color: linear-gradient(to bottom right, #1565c0, #0d47a1);                                    -fx-background-radius: 8px; -fx-cursor: hand;" text="◀  Back" />

                    <!-- Step counter -->
                    <Label fx:id="stepCounterLabel" style="-fx-font-family: Verdana; -fx-font-size: 12px;                                   -fx-font-weight: bold; -fx-text-fill: #ce93d8;                                   -fx-background-color: rgba(123,47,247,0.2);                                   -fx-background-radius: 6; -fx-padding: 6 10 6 10;" text="0 / 0" />

                    <!-- Fwd ▶ -->
                    <Button fx:id="stepFwdBtn" disable="true" onAction="#onStepForward" prefHeight="36" prefWidth="90" style="-fx-font-family: Verdana; -fx-font-size: 12px;                                    -fx-font-weight: bold; -fx-text-fill: white;                                    -fx-background-color: linear-gradient(to bottom right, #6a1b9a, #4a148c);                                    -fx-background-radius: 8px; -fx-cursor: hand;" text="Fwd  ▶" />
                </HBox>
            </VBox>

        </HBox>

        <!-- ── STATUS BAR ── -->
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: rgba(123,47,247,0.1);                      -fx-border-color: rgba(123,47,247,0.25);                      -fx-border-width: 0 0 1 0;                      -fx-padding: 6 24 6 24;" />

        <!-- ── TAB PANE (headers hidden) ── -->
        <TabPane fx:id="searchTabPane" style="-fx-background-color: transparent;                         -fx-tab-min-height: 0; -fx-tab-max-height: 0;" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

            <!-- ════ LINEAR SEARCH TAB ════ -->
            <Tab fx:id="linearTab" text="Linear">
                <AnchorPane style="-fx-background-color: transparent;">

                    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: rgba(255,255,255,0.02);                                  -fx-border-color: rgba(123,47,247,0.2);                                  -fx-border-width: 0 0 1 0; -fx-padding: 7 24 7 24;" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

                        <HBox alignment="CENTER" spacing="8" style="-fx-background-color: rgba(128,203,196,0.12);                                      -fx-background-radius: 6; -fx-padding: 4 10 4 10;">
                            <Label style="-fx-text-fill: #80CBC4; -fx-font-family: Verdana;                                           -fx-font-size: 11px; -fx-font-weight: bold;" text="LINEAR SEARCH" />
                        </HBox>

                        <Label style="-fx-text-fill: rgba(170,170,170,0.7);                                       -fx-font-family: Verdana; -fx-font-size: 11px;" text="Visits each element one by one from left to right" />

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER" spacing="8" style="-fx-background-color: rgba(255,183,77,0.12);                                      -fx-background-radius: 6; -fx-padding: 4 10 4 10;">
                            <Label style="-fx-text-fill: #FFB74D; -fx-font-family: Verdana;                                           -fx-font-size: 11px; -fx-font-weight: bold;" text="⏱  Worst Case: O(n)" />
                        </HBox>

                        <HBox alignment="CENTER" spacing="8" style="-fx-background-color: rgba(123,47,247,0.15);                                      -fx-background-radius: 6; -fx-padding: 4 10 4 10;">
                            <Label fx:id="linearStepLabel" style="-fx-text-fill: #ce93d8; -fx-font-family: Verdana;                                           -fx-font-size: 11px; -fx-font-weight: bold;" text="Step: 0 / 0" />
                        </HBox>
                    </HBox>

                    <Pane fx:id="linearVisualPane" style="-fx-background-color: transparent;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="38" />
                </AnchorPane>
            </Tab>

            <!-- ════ BINARY SEARCH TAB ════ -->
            <Tab fx:id="binaryTab" text="Binary">
                <AnchorPane style="-fx-background-color: transparent;">

                    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: rgba(255,255,255,0.02);                                  -fx-border-color: rgba(123,47,247,0.2);                                  -fx-border-width: 0 0 1 0; -fx-padding: 7 24 7 24;" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

                        <HBox alignment="CENTER" spacing="8" style="-fx-background-color: rgba(128,203,196,0.12);                                      -fx-background-radius: 6; -fx-padding: 4 10 4 10;">
                            <Label style="-fx-text-fill: #80CBC4; -fx-font-family: Verdana;                                           -fx-font-size: 11px; -fx-font-weight: bold;" text="BINARY SEARCH" />
                        </HBox>

                        <Label style="-fx-text-fill: rgba(170,170,170,0.7);                                       -fx-font-family: Verdana; -fx-font-size: 11px;" text="Divides sorted array in half each step — array is auto-sorted" />

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER" spacing="6" style="-fx-background-color: rgba(79,195,247,0.1);                                      -fx-background-radius: 6; -fx-padding: 4 10 4 10;">
                            <Label fx:id="loLabel" style="-fx-text-fill: #4FC3F7; -fx-font-family: Verdana;                                           -fx-font-size: 11px; -fx-font-weight: bold;" text="lo=—" />
                            <Label style="-fx-text-fill: rgba(123,47,247,0.4);" text="|" />
                            <Label fx:id="midLabel" style="-fx-text-fill: #FFD54F; -fx-font-family: Verdana;                                           -fx-font-size: 11px; -fx-font-weight: bold;" text="mid=—" />
                            <Label style="-fx-text-fill: rgba(123,47,247,0.4);" text="|" />
                            <Label fx:id="hiLabel" style="-fx-text-fill: #EF5350; -fx-font-family: Verdana;                                           -fx-font-size: 11px; -fx-font-weight: bold;" text="hi=—" />
                        </HBox>

                        <HBox alignment="CENTER" spacing="8" style="-fx-background-color: rgba(255,183,77,0.12);                                      -fx-background-radius: 6; -fx-padding: 4 10 4 10;">
                            <Label style="-fx-text-fill: #FFB74D; -fx-font-family: Verdana;                                           -fx-font-size: 11px; -fx-font-weight: bold;" text="⏱  Worst Case: O(log n)" />
                        </HBox>

                        <HBox alignment="CENTER" spacing="8" style="-fx-background-color: rgba(123,47,247,0.15);                                      -fx-background-radius: 6; -fx-padding: 4 10 4 10;">
                            <Label fx:id="binaryStepLabel" style="-fx-text-fill: #ce93d8; -fx-font-family: Verdana;                                           -fx-font-size: 11px; -fx-font-weight: bold;" text="Step: 0 / 0" />
                        </HBox>
                    </HBox>

                    <Pane fx:id="binaryVisualPane" style="-fx-background-color: transparent;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="38" />
                </AnchorPane>
            </Tab>

        </TabPane>

    </VBox>

</AnchorPane>
